APP_ENV=local
API_PORT=8000

DATABASE_URL=postgresql+asyncpg://cortex:cortex@postgres:5432/cortex
REDIS_URL=redis://redis:6379/0

# LLM provider: none | openai | google
LLM_PROVIDER=google

# OpenAI fields are ignored when LLM_PROVIDER=google
LLM_MODEL=
LLM_API_KEY=

# Google / Gemini / Gemma
# Keep the same key in all 3 names to satisfy your app + LangChain integrations.
GOOGLE_AI_API_KEY=PASTE_YOUR_REAL_KEY_HERE
GOOGLE_API_KEY=PASTE_YOUR_REAL_KEY_HERE
GEMINI_API_KEY=PASTE_YOUR_REAL_KEY_HERE

# Main/default model.
# IMPORTANT: use bare model name for LangChain/app config, not "models/gemma-4-31b-it".
GOOGLE_AI_MODEL=gemma-4-31b-it

# Intake model. Keep same for now until stable.
GOOGLE_AI_INTAKE_MODEL=gemma-4-31b-it

# Layer 3 Analyst/Critic model. If empty, Layer 3 falls back to GOOGLE_AI_MODEL.
GOOGLE_AI_LAYER3_MODEL=gemma-4-31b-it

# Layer 4 Report Agent model. If empty, Layer 4 falls back to GOOGLE_AI_LAYER3_MODEL,
# then GOOGLE_AI_MODEL.
GOOGLE_AI_LAYER4_MODEL=

INTAKE_MAX_OUTPUT_TOKENS=2048
LAYER3_MAX_OUTPUT_TOKENS=4096
LAYER4_MAX_OUTPUT_TOKENS=4096

# Redis artifact cache for /api/v1/cortex/full-message.
ORCHESTRATOR_CACHE_ENABLED=true
ORCHESTRATOR_CACHE_TTL_SECONDS=604800

# Gemini 2.5 thinking budget controls.
# -2 = do not send the parameter, -1 = dynamic, 0 = disabled where supported,
# positive integer = cap thinking tokens.
GOOGLE_AI_THINKING_BUDGET=-2
GOOGLE_AI_INTAKE_THINKING_BUDGET=-2
GOOGLE_AI_LAYER3_THINKING_BUDGET=-2
GOOGLE_AI_LAYER4_THINKING_BUDGET=0

LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=cortex-api
