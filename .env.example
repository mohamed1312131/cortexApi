APP_ENV=local
API_PORT=8000
DATABASE_URL=postgresql+asyncpg://cortex:cortex@postgres:5432/cortex
REDIS_URL=redis://redis:6379/0
# LLM provider: none | openai | google
LLM_PROVIDER=google
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=cortex-api
GOOGLE_AI_API_KEY=
GOOGLE_AI_MODEL=gemma-4-26b-a4b-it
# Empty -> falls back to GOOGLE_AI_MODEL.
GOOGLE_AI_INTAKE_MODEL=gemma-4-31b-it
INTAKE_MAX_OUTPUT_TOKENS=2048
