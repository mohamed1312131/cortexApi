  "fit_rules": [
    {
      "rule_id": "E_FIT_001",
      "rule_name": "Piece dimensions required for heavy/oversized",
      "applies_to_codes": "HEA,BIG,OHG",
      "condition": "piece_weight_or_dimensions_missing",
      "action": "hard_gate",
      "confidence_cap_percent": 40,
      "message": "Heavy/outsized/overhang cargo cannot be assessed without piece weight and dimensions."
    },
    {
      "rule_id": "E_FIT_002",
      "rule_name": "Passenger belly height limit",
      "applies_to_codes": "HEA,BIG,OHG,general_cargo",
      "condition": "piece_height_cm > selected_aircraft.lower_deck_max_loading_height_cm",
      "action": "require_freighter_or_main_deck",
      "confidence_cap_percent": 55,
      "message": "Cargo height exceeds lower-deck passenger/belly reference height; require main-deck freighter check."
    },
    {
      "rule_id": "E_FIT_003",
      "rule_name": "Cargo door check",
      "applies_to_codes": "HEA,BIG,OHG,ACT,BUP",
