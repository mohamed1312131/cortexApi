 "lane_inference_rule": {
  "description": "v1 approximation for 'freighter available on lane A->B'",
  "rule": "IF origin_hub in any carrier.home_hubs OR is mega_hub/major_cargo_hub AND destination_hub likewise, THEN freighter service is plausible (list matching carriers). ELSE assume belly-only or requires transshipment via nearest mega_hub.",
  "freighter_needed_when": "cargo > ~15t OR oversized OR main-deck-only DG OR needs nose-door loading",
  "belly_sufficient_when": "cargo < ~15t AND fits LD3/LD6 AND not main-deck-restricted"
 }
